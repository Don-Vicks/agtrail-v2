# Base URL for the backend API (Swagger). Include /api when routes are mounted at /api/... (e.g. /api/reports/farmer/...).
VITE_API_BASE_URL=http://localhost:8000/api
# Set to true to log every API request/response (URL, redacted headers, body, parsed JSON) in the browser console—even in production builds.
VITE_DEBUG_API=false
VITE_DEFAULT_ORGANIZATION_ID=

# Google Maps (Maps JavaScript API — enable in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=

# Stellar block explorer (stellar.expert): testnet | public | futurenet. Defaults to testnet.
VITE_STELLAR_NETWORK=testnet
# Optional EVM explorer base for 0x addresses, e.g. https://etherscan.io — account URLs are `{prefix}/address/{addr}`.
# VITE_EVM_EXPLORER_ADDRESS_URL_PREFIX=

# Dojah (dummy/test values)
VITE_DOJAH_APP_ID=
VITE_DOJAH_PUBLIC_KEY=
VITE_DOJAH_SANDBOX=true
